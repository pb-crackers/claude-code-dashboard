# ── Docker ────────────────────────────────────────────────────────────────────
# Path on your HOST machine containing the projects you want to work on.
# This gets mounted to /workspace inside the container.
HOST_BASE_DIR=/path/to/your/projects

# ── Server ────────────────────────────────────────────────────────────────────
# Inside Docker this should be /workspace (maps to HOST_BASE_DIR above).
# Running locally, set this to your actual projects directory.
BASE_DIR=/workspace

# ── Authentication ────────────────────────────────────────────────────────────
# Set to false to disable the login page entirely (useful on a trusted network).
# Defaults to true if not set.
REQUIRE_AUTH=true

# Comma-separated username:password pairs.
# Example: AUTH_USERS=alice:mypassword,bob:anotherpassword
AUTH_USERS=admin:changeme

# Random secret used to sign session cookies — change this before deploying!
SESSION_SECRET=change-this-to-something-random

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the claude binary path (auto-detected from login shell if not set).
# Useful inside Docker where claude is at a known location.
# CLAUDE_BIN=/usr/local/bin/claude
